# This file contains sample local configuration values.
# Copy this file to "local.properties" (which is git-ignored) and fill in your own values.
# DO NOT commit local.properties or real API keys to version control.

# Path to the Android SDK (auto-generated by Android Studio, usually not needed manually)
# sdk.dir=/path/to/Android/sdk

# AI Provider API Keys (used by BuildConfig fields, see app/build.gradle.kts)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Web client ID for Google Sign-In (from Firebase project's google-services.json)
GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here
